{
  "name": "project-experience-artifacts",
  "version": "2.0.0",
  "description": "Automated system for generating professional artifacts from project data",
  "type": "module",
  "private": true,
  "scripts": {
    "extract-git": "bun run tools/extractGitData.ts",
    "process-backlog": "bun run tools/processBacklog.ts",
    "validate-artifacts": "bun run tools/validateArtifacts.ts",
    "analyze-project": "bun run scripts/analyzeProject.ts",
    "generate-bio": "bun run scripts/generateBio.ts",
    "validate-output": "bun run scripts/validateOutput.ts",
    "compare-projects": "bun run scripts/compareProjects.ts",
    "configure-ai": "bun run scripts/configureAI.ts",
    "dev": "bun run --watch",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.22",
    "@anthropic-ai/sdk": "^0.63.0",
    "ai": "^4.3.16",
    "csv-parser": "^3.0.0",
    "zod": "^3.22.4"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "professional-development",
    "biography-generation",
    "project-analysis",
    "ai-automation",
    "typescript"
  ]
}
